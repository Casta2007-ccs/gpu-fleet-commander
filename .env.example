# GPU Fleet Commander Environment Configuration Template
# Copy this file to .env and configure your secrets

# Security & API Authentication
API_KEY=gpu_fleet_secure_token_2026

# Database Connection (PostgreSQL with AsyncPG driver)
DATABASE_URL=postgresql+asyncpg://postgres:gpu_fleet_secure_db_pass_2026@localhost:5432/gpu_fleet

# Message Broker (Redis Pub/Sub)
REDIS_URL=redis://localhost:6379/0
