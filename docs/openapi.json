{
  "openapi": "3.1.0",
  "info": {
    "title": "GPU Fleet Commander API",
    "description": "Control Plane and Telemetry Ingestion Hub for distributed worker nodes.",
    "version": "1.0.0"
  },
  "paths": {
    "/v1/nodes": {
      "post": {
        "summary": "Register a worker node",
        "operationId": "register_node_v1_nodes_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Access API Key for control plane authentication",
              "title": "X-Api-Key"
            },
            "description": "Access API Key for control plane authentication"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NodeRegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NodeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List all registered worker nodes",
        "operationId": "list_nodes_v1_nodes_get",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Access API Key for control plane authentication",
              "title": "X-Api-Key"
            },
            "description": "Access API Key for control plane authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NodeResponse"
                  },
                  "title": "Response List Nodes V1 Nodes Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/nodes/{node_id}/heartbeat": {
      "post": {
        "summary": "Ingest heartbeat signal",
        "operationId": "process_heartbeat_v1_nodes__node_id__heartbeat_post",
        "parameters": [
          {
            "name": "node_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Node Id"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Access API Key for control plane authentication",
              "title": "X-Api-Key"
            },
            "description": "Access API Key for control plane authentication"
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks": {
      "post": {
        "summary": "Create a computational task",
        "operationId": "create_task_v1_tasks_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Access API Key for control plane authentication",
              "title": "X-Api-Key"
            },
            "description": "Access API Key for control plane authentication"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{task_id}/dispatch": {
      "post": {
        "summary": "Dispatch task to online node",
        "operationId": "dispatch_task_v1_tasks__task_id__dispatch_post",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
